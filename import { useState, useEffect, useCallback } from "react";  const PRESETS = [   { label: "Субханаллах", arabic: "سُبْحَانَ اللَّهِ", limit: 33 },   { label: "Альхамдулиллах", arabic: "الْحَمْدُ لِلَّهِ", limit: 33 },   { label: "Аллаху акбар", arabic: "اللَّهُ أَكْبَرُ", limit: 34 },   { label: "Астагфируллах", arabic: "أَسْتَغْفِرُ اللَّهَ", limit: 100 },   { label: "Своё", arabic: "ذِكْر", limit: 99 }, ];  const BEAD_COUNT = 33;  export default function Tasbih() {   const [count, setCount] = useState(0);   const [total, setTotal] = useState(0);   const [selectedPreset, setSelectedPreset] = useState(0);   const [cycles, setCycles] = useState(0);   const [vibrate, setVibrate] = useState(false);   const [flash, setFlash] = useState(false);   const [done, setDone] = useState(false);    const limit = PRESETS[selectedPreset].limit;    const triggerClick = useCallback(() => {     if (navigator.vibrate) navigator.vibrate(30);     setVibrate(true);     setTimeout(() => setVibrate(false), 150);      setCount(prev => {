import { useState, useEffect, useCallback } from "react";

const PRESETS = [
  { label: "Субханаллах", arabic: "سُبْحَانَ اللَّهِ", limit: 33 },
  { label: "Альхамдулиллах", arabic: "الْحَمْدُ لِلَّهِ", limit: 33 },
  { label: "Аллаху акбар", arabic: "اللَّهُ أَكْبَرُ", limit: 34 },
  { label: "Астагфируллах", arabic: "أَسْتَغْفِرُ اللَّهَ", limit: 100 },
  { label: "Своё", arabic: "ذِكْر", limit: 99 },
];

const BEAD_COUNT = 33;

export default function Tasbih() {
  const [count, setCount] = useState(0);
  const [total, setTotal] = useState(0);
  const [selectedPreset, setSelectedPreset] = useState(0);
  const [cycles, setCycles] = useState(0);
  const [vibrate, setVibrate] = useState(false);
  const [flash, setFlash] = useState(false);
  const [done, setDone] = useState(false);

  const limit = PRESETS[selectedPreset].limit;

  const triggerClick = useCallback(() => {
    if (navigator.vibrate) navigator.vibrate(30);
    setVibrate(true);
    setTimeout(() => setVibrate(false), 150);

    setCount(prev => {
      const next = prev + 1;
      setTotal(t => t + 1);
      if (next >= limit) {
        setCycles(c => c + 1);
        setFlash(true);
        setDone(true);
        setTimeout(() => setFlash(false), 600);
        setTimeout(() => setDone(false), 1800);
        return 0;
      }
      return next;
    });
  }, [limit]);

  // Tap anywhere on screen
  useEffect(() => {
    const handler = (e) => {
      // avoid tapping buttons triggering twice
      if (e.target.closest("button") && !e.target.closest("#tap-zone")) return;
      triggerClick();
    };
    document.getElementById("tap-zone")?.addEventListener("click", handler);
    return () => document.getElementById("tap-zone")?.removeEventListener("click", handler);
  }, [triggerClick]);

  // Keyboard support
  useEffect(() => {
    const handler = (e) => {
      if (e.code === "Space" || e.code === "Enter") triggerClick();
    };
    window.addEventListener("keydown", handler);
    return () => window.removeEventListener("keydown", handler);
  }, [triggerClick]);

  const reset = () => {
    setCount(0);
    setTotal(0);
    setCycles(0);
    setDone(false);
  };

  const progress = count / limit;
  const r = 110;
  const cx = 140, cy = 140;
  const circumference = 2 * Math.PI * r;
  const offset = circumference * (1 - progress);

  // Bead positions
  const beads = Array.from({ length: BEAD_COUNT }, (_, i) => {
    const angle = (i / BEAD_COUNT) * 2 * Math.PI - Math.PI / 2;
    return {
      x: cx + r * Math.cos(angle),
      y: cy + r * Math.sin(angle),
      lit: i < (count % BEAD_COUNT || (count >= limit ? BEAD_COUNT : count % BEAD_COUNT)),
    };
  });

  return (
    <div style={{
      minHeight: "100dvh",
      background: "linear-gradient(160deg, #0d1b2a 0%, #1a2f4a 60%, #0d2235 100%)",
      display: "flex",
      flexDirection: "column",
      alignItems: "center",
      justifyContent: "space-between",
      padding: "24px 16px 32px",
      fontFamily: "'Georgia', serif",
      userSelect: "none",
      WebkitUserSelect: "none",
      color: "#e8d5a3",
      boxSizing: "border-box",
    }}>

      {/* Header */}
      <div style={{ textAlign: "center", width: "100%" }}>
        <div style={{
          fontSize: 13,
          letterSpacing: 3,
          textTransform: "uppercase",
          color: "#8aab9e",
          marginBottom: 4,
          fontFamily: "system-ui, sans-serif",
        }}>Тасбих</div>
        <div style={{ fontSize: 28, color: "#c9a96e", direction: "rtl", letterSpacing: 2 }}>
          {PRESETS[selectedPreset].arabic}
        </div>
        <div style={{ fontSize: 13, color: "#8aab9e", marginTop: 2, fontFamily: "system-ui, sans-serif" }}>
          {PRESETS[selectedPreset].label}
        </div>
      </div>

      {/* Preset selector */}
      <div style={{
        display: "flex",
        gap: 6,
        flexWrap: "wrap",
        justifyContent: "center",
        width: "100%",
      }}>
        {PRESETS.map((p, i) => (
          <button key={i} onClick={(e) => { e.stopPropagation(); setSelectedPreset(i); reset(); }} style={{
            background: selectedPreset === i ? "#c9a96e" : "rgba(255,255,255,0.07)",
            color: selectedPreset === i ? "#0d1b2a" : "#c9a96e",
            border: "1px solid " + (selectedPreset === i ? "#c9a96e" : "rgba(201,169,110,0.3)"),
            borderRadius: 20,
            padding: "5px 12px",
            fontSize: 11,
            cursor: "pointer",
            fontFamily: "system-ui, sans-serif",
            fontWeight: selectedPreset === i ? "700" : "400",
            transition: "all 0.2s",
          }}>
            {p.label}
          </button>
        ))}
      </div>

      {/* Main tap zone */}
      <div id="tap-zone" style={{
        position: "relative",
        width: 280,
        height: 280,
        cursor: "pointer",
        flexShrink: 0,
      }}>
        <svg width="280" height="280" viewBox="0 0 280 280">
          {/* Background circle */}
          <circle cx={cx} cy={cy} r={r} fill="none" stroke="rgba(255,255,255,0.05)" strokeWidth={18} />
          {/* Progress arc */}
          <circle
            cx={cx} cy={cy} r={r}
            fill="none"
            stroke="url(#goldGrad)"
            strokeWidth={18}
            strokeDasharray={circumference}
            strokeDashoffset={offset}
            strokeLinecap="round"
            transform={`rotate(-90 ${cx} ${cy})`}
            style={{ transition: "stroke-dashoffset 0.25s ease" }}
          />
          {/* Beads */}
          {beads.map((b, i) => (
            <circle key={i} cx={b.x} cy={b.y} r={5}
              fill={b.lit ? "#c9a96e" : "rgba(201,169,110,0.15)"}
              style={{ transition: "fill 0.2s" }}
            />
          ))}
          <defs>
            <linearGradient id="goldGrad" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stopColor="#e8c97e" />
              <stop offset="100%" stopColor="#a06c2c" />
            </linearGradient>
          </defs>
        </svg>

        {/* Center counter */}
        <div style={{
          position: "absolute",
          top: "50%", left: "50%",
          transform: "translate(-50%, -50%)",
          textAlign: "center",
          pointerEvents: "none",
        }}>
          {done ? (
            <div style={{ fontSize: 36, color: "#c9a96e", animation: "pulse 0.4s ease" }}>✓</div>
          ) : (
            <>
              <div style={{
                fontSize: 64,
                fontWeight: "700",
                color: flash ? "#ffffff" : "#e8d5a3",
                lineHeight: 1,
                transition: "color 0.2s",
                transform: vibrate ? "scale(1.08)" : "scale(1)",
                transitionProperty: "transform, color",
                transitionDuration: "0.15s",
              }}>
                {count}
              </div>
              <div style={{ fontSize: 13, color: "#8aab9e", fontFamily: "system-ui, sans-serif" }}>
                из {limit}
              </div>
            </>
          )}
        </div>
      </div>

      {/* Stats */}
      <div style={{
        display: "flex",
        gap: 32,
        textAlign: "center",
      }}>
        <div>
          <div style={{ fontSize: 24, color: "#c9a96e", fontWeight: "700" }}>{cycles}</div>
          <div style={{ fontSize: 11, color: "#8aab9e", fontFamily: "system-ui, sans-serif", letterSpacing: 1 }}>ЦИКЛОВ</div>
        </div>
        <div>
          <div style={{ fontSize: 24, color: "#c9a96e", fontWeight: "700" }}>{total}</div>
          <div style={{ fontSize: 11, color: "#8aab9e", fontFamily: "system-ui, sans-serif", letterSpacing: 1 }}>ВСЕГО</div>
        </div>
      </div>

      {/* Reset */}
      <button onClick={(e) => { e.stopPropagation(); reset(); }} style={{
        background: "transparent",
        border: "1px solid rgba(201,169,110,0.4)",
        color: "#8aab9e",
        borderRadius: 24,
        padding: "10px 32px",
        fontSize: 13,
        cursor: "pointer",
        fontFamily: "system-ui, sans-serif",
        letterSpacing: 1,
        transition: "all 0.2s",
      }}>
        Сбросить
      </button>

      <style>{`
        @keyframes pulse {
          0% { transform: scale(1); }
          50% { transform: scale(1.3); }
          100% { transform: scale(1); }
        }
        * { -webkit-tap-highlight-color: transparent; }
      `}</style>
    </div>
  );
}
